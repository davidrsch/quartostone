{
  "name": "quartostone",
  "version": "0.1.0",
  "description": "A Notion-like, Git-native knowledge base built on Quarto",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "quartostone": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:client": "vite build",
    "build:all": "npm run build && npm run build:client",
    "dev:server": "tsx watch src/cli/commands/serve.ts",
    "dev:client": "vite",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "simple-git": "^3.27.0",
    "ws": "^8.18.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/lang-yaml": "^6.1.1",
    "@codemirror/language-data": "^6.5.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "typescript-eslint": "^8.0.0",
    "codemirror": "^6.0.1",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  },
  "license": "MIT",
  "keywords": ["quarto", "notion", "knowledge-base", "git", "markdown", "literate-computing"]
}
